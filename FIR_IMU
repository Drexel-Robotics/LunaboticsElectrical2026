//Use in ArduinoIDE
#include "Wire.h"

// ---- IMU Defines ----
#define MPU9250_IMU_ADDRESS      0x68
#define GYRO_FULL_SCALE_1000_DPS 0x10
#define ACC_FULL_SCALE_2G        0x00
#define TEMPERATURE_OFFSET       21
#define INTERVAL_MS_PRINT        10    // 10ms = 100Hz for Serial Plotter

// ---- FIR Settings ----
// NUM_TAPS: number of samples in the filter window
// More taps = smoother output but more lag
// Less taps = faster response but less smoothing
// Good starting range: 5 (light) to 20 (heavy)
#define NUM_TAPS 10

// ---- FIR Buffers (one per axis per sensor) ----
float ax_buf[NUM_TAPS] = {0};
float ay_buf[NUM_TAPS] = {0};
float az_buf[NUM_TAPS] = {0};
float gx_buf[NUM_TAPS] = {0};
float gy_buf[NUM_TAPS] = {0};
float gz_buf[NUM_TAPS] = {0};
int fir_idx = 0;

// ---- IMU Raw Structs ----
struct { int16_t x, y, z; } gyroscope;
struct { int16_t x, y, z; } accelerometer;
struct { int16_t value;   } temperature;

// ---- Normalized values (real units) ----
struct {
  struct { float x, y, z; } accelerometer;  // g's
  struct { float x, y, z; } gyroscope;      // degrees/sec
  float temperature;                         // celsius
} normalized;

// ---- FIR filtered output ----
struct {
  struct { float x, y, z; } accelerometer;
  struct { float x, y, z; } gyroscope;
} filtered;

unsigned long lastPrintMillis = 0;

// =============================
// Wire.h I2C Helpers
// =============================
void I2CwriteByte(uint8_t address, uint8_t reg, uint8_t data) {
  Wire.beginTransmission(address);
  Wire.write(reg);
  Wire.write(data);
  Wire.endTransmission();
}

void I2Cread(uint8_t address, uint8_t reg, uint8_t length, uint8_t* buffer) {
  Wire.beginTransmission(address);
  Wire.write(reg);
  Wire.endTransmission(false);
  Wire.requestFrom(address, length);
  for (int i = 0; i < length; i++) {
    buffer[i] = Wire.read();
  }
}

// =============================
// FIR Filter Function
// =============================
// Inserts new sample into circular buffer and returns the moving average
// Each axis has its own buffer passed in — they all share the same index
float fir_filter(float* buffer, float new_sample) {
  buffer[fir_idx] = new_sample;
  float sum = 0;
  for (int i = 0; i < NUM_TAPS; i++) {
    sum += buffer[i];
  }
  return sum / NUM_TAPS;
}

// =============================
// IMU Ready Check
// =============================
bool isImuReady() {
  uint8_t isReady;
  I2Cread(MPU9250_IMU_ADDRESS, 58, 1, &isReady);
  return isReady & 0x01;
}

// =============================
// Read Raw IMU Data
// =============================
void readRawImu() {
  uint8_t buff[14];
  I2Cread(MPU9250_IMU_ADDRESS, 59, 14, buff);

  accelerometer.x  = (buff[0]  << 8 | buff[1]);
  accelerometer.y  = (buff[2]  << 8 | buff[3]);
  accelerometer.z  = (buff[4]  << 8 | buff[5]);
  temperature.value = (buff[6] << 8 | buff[7]);
  gyroscope.x      = (buff[8]  << 8 | buff[9]);
  gyroscope.y      = (buff[10] << 8 | buff[11]);
  gyroscope.z      = (buff[12] << 8 | buff[13]);
}

// =============================
// Normalize to Real Units
// =============================
void normalizeImu() {
  // Accelerometer: +-2g range -> divide by 16384 -> g's
  normalized.accelerometer.x = accelerometer.x / 16384.0;
  normalized.accelerometer.y = accelerometer.y / 16384.0;
  normalized.accelerometer.z = accelerometer.z / 16384.0;

  // Gyroscope: 1000 DPS range -> divide by 32.8 -> degrees/sec
  normalized.gyroscope.x = gyroscope.x / 32.8;
  normalized.gyroscope.y = gyroscope.y / 32.8;
  normalized.gyroscope.z = gyroscope.z / 32.8;

  // Temperature
  normalized.temperature = ((temperature.value - TEMPERATURE_OFFSET) / 333.87) + TEMPERATURE_OFFSET;
}

// =============================
// Apply FIR Filter to All Axes
// =============================
void applyFirFilter() {
  // Filter each axis — all share the same buffer index
  filtered.accelerometer.x = fir_filter(ax_buf, normalized.accelerometer.x);
  filtered.accelerometer.y = fir_filter(ay_buf, normalized.accelerometer.y);
  filtered.accelerometer.z = fir_filter(az_buf, normalized.accelerometer.z);
  filtered.gyroscope.x     = fir_filter(gx_buf, normalized.gyroscope.x);
  filtered.gyroscope.y     = fir_filter(gy_buf, normalized.gyroscope.y);
  filtered.gyroscope.z     = fir_filter(gz_buf, normalized.gyroscope.z);

  // Advance circular buffer index after all axes processed
  fir_idx = (fir_idx + 1) % NUM_TAPS;
}

// =============================
// Setup
// =============================
void setup() {
  Wire.begin();
  Serial.begin(115200);

  I2CwriteByte(MPU9250_IMU_ADDRESS, 27, GYRO_FULL_SCALE_1000_DPS);
  I2CwriteByte(MPU9250_IMU_ADDRESS, 28, ACC_FULL_SCALE_2G);
  I2CwriteByte(MPU9250_IMU_ADDRESS, 55, 0x02);
  I2CwriteByte(MPU9250_IMU_ADDRESS, 56, 0x01);
}

// =============================
// Loop
// =============================
void loop() {
  unsigned long currentMillis = millis();

  if (isImuReady()) {
    readRawImu();
    normalizeImu();
    applyFirFilter();
  }

  // Serial Plotter — raw vs FIR filtered for all axes
  if (currentMillis - lastPrintMillis >= INTERVAL_MS_PRINT) {

    // Accelerometer — raw vs filtered (g's)
    Serial.print("Acc_X_Raw:"); Serial.print(normalized.accelerometer.x, 3);
    Serial.print(",");
    Serial.print("Acc_X_FIR:"); Serial.print(filtered.accelerometer.x, 3);
    Serial.print(",");
    Serial.print("Acc_Y_Raw:"); Serial.print(normalized.accelerometer.y, 3);
    Serial.print(",");
    Serial.print("Acc_Y_FIR:"); Serial.print(filtered.accelerometer.y, 3);
    Serial.print(",");
    Serial.print("Acc_Z_Raw:"); Serial.print(normalized.accelerometer.z, 3);
    Serial.print(",");
    Serial.print("Acc_Z_FIR:"); Serial.print(filtered.accelerometer.z, 3);
    Serial.print(",");

    // Gyroscope — raw vs filtered (degrees/sec)
    Serial.print("Gyr_X_Raw:"); Serial.print(normalized.gyroscope.x, 3);
    Serial.print(",");
    Serial.print("Gyr_X_FIR:"); Serial.print(filtered.gyroscope.x, 3);
    Serial.print(",");
    Serial.print("Gyr_Y_Raw:"); Serial.print(normalized.gyroscope.y, 3);
    Serial.print(",");
    Serial.print("Gyr_Y_FIR:"); Serial.print(filtered.gyroscope.y, 3);
    Serial.print(",");
    Serial.print("Gyr_Z_Raw:"); Serial.print(normalized.gyroscope.z, 3);
    Serial.print(",");
    Serial.print("Gyr_Z_FIR:"); Serial.println(filtered.gyroscope.z, 3);

    lastPrintMillis = currentMillis;
  }
}
